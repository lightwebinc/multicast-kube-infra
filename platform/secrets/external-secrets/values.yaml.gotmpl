# External Secrets Operator — minimal install.
#
# The operator runs cluster-wide; ClusterSecretStore CRs are applied separately
# (see ../cluster-secret-store.example.yaml). No provider is wired by default.

installCRDs: true

replicaCount: 1
webhook:
  replicaCount: 1
certController:
  replicaCount: 1

# Disable the bitnami subchart (only needed for some examples).
bitwarden-sdk-server:
  enabled: false
