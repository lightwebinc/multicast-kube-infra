# shellcheck shell=bash
# Copy to hosts.env and edit. hosts.env is .gitignored.
#
# k0sctl reads these via envsubst-style rendering from k0sctl.yaml.

# SSH user with passwordless sudo on every target host.
export SSH_USER="ubuntu"
export SSH_KEY="${HOME}/.ssh/id_ed25519"

# Controller + integrated worker (single-node default).
export NODE0_HOST="k0s-node0.example.lan"
export NODE0_ADDR="192.168.0.40"
export NODE0_FABRIC_IFACE="enp5s0"
export NODE0_FABRIC_ADDR="fd20::40"

# HA control plane (3 dedicated controllers) — uncomment with the k0sctl.yaml
# controller hosts + CPLB in k0s-config. CP_VIP is the apiserver VIP.
# export CP_VIP="192.168.0.10"
# export CP1_ADDR="192.168.0.11"
# export CP2_ADDR="192.168.0.12"
# export CP3_ADDR="192.168.0.13"

# Optional additional workers — uncomment and add to k0sctl.yaml when scaling out.
# export NODE1_HOST="k0s-node1.example.lan"
# export NODE1_ADDR="192.168.0.41"
# export NODE1_FABRIC_IFACE="enp5s0"
# export NODE1_FABRIC_ADDR="fd20::41"
#
# export NODE2_HOST="k0s-node2.example.lan"
# export NODE2_ADDR="192.168.0.42"
# export NODE2_FABRIC_IFACE="enp5s0"
# export NODE2_FABRIC_ADDR="fd20::42"
