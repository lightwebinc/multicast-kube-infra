# k0s ClusterConfig — copy to k0s-config.yaml and edit.
#
# bootstrap.sh inlines this file into k0sctl.yaml under spec.k0s.config.
#
# `provider: custom` means k0s does NOT install a built-in CNI; the platform
# layer (`make platform CNI=calico|cilium`) installs one explicitly. Set
# `provider: kuberouter` (and `make platform CNI=kube-router`) if you want the
# k0s-bundled CNI.

apiVersion: k0s.k0sproject.io/v1beta1
kind: ClusterConfig
metadata:
  name: k0s
spec:
  # HA control plane (3 dedicated controllers): float an apiserver VIP with CPLB.
  # LESSONS FROM THE L2-adjacent reference cluster migration, all the hard way:
  #  - Put the VIP in `api.sans` ONLY, NOT `api.externalAddress`: an external API
  #    address is mutually exclusive with nodeLocalLoadBalancing (NLLB), and NLLB is
  #    required (see below). The cert still covers the VIP via the SAN; CPLB floats it.
  #  - Do NOT add CPLB `virtualServers`: that IPVS-balances ONLY the apiserver (6443)
  #    and leaves konnectivity (8132) on the VRRP master alone, so apiservers on the
  #    other controllers can't reach pods → admission webhooks / metrics / logs fail
  #    "No agent available". Pure VRRP (active/passive) keeps apiserver+konnectivity
  #    co-located; konnectivity HA comes from NLLB instead.
  #  - Each controller's k0sctl host needs `privateAddress: <real IP>`, else k0sctl
  #    auto-detects the live VIP and writes it as etcd `peerAddress` → etcd crashloops
  #    "bind: cannot assign requested address" when VRRP moves the VIP.
  api:
    sans: [10.0.0.10]            # the CPLB VIP (cert SAN only; NOT externalAddress)
  network:
    provider: custom
    podCIDR: 10.244.0.0/16
    serviceCIDR: 10.96.0.0/12
    dualStack:
      enabled: true
      IPv6podCIDR: "fd20:0:0:1::/64"
      IPv6serviceCIDR: "fd30:0:0:1::/108"
    # Cilium owns eBPF kube-proxy-replacement — disable the bundled kube-proxy.
    kubeProxy:
      disabled: true
    # REQUIRED for konnectivity HA behind dedicated controllers: a per-worker envoy
    # balances internal node->control-plane traffic (kubelet + konnectivity-agent)
    # across ALL controllers, so every apiserver has konnectivity agents. The agent
    # then targets localhost:7132 and the apiserver is served at 127.0.0.1:7443 — the
    # endpoint Cilium must use as k8sServiceHost (see cni/cilium/values.yaml.gotmpl).
    nodeLocalLoadBalancing:
      enabled: true
      type: EnvoyProxy
    controlPlaneLoadBalancing:
      enabled: true
      type: Keepalived
      keepalived:
        vrrpInstances:
          - virtualIPs: [10.0.0.10/24]
            authPass: CHANGEME    # VRRP password must be <= 8 chars (keepalived limit)
        # NO virtualServers — see the lesson above.
  telemetry:
    enabled: false
  # Worker profiles set kubelet config for a class of workers. The `dataplane`
  # profile is the W2 substrate (docs/production/02): exclusive NUMA-local cores
  # for Guaranteed-QoS AF_XDP/SR-IOV pods. A node opts in with
  # `--profile dataplane` (k0sctl host installFlags). Harmless until referenced.
  workerProfiles:
    - name: dataplane
      values:
        cpuManagerPolicy: static
        topologyManagerPolicy: single-numa-node
        memoryManager:
          policy: Static
        # Reserve cores/memory off the allocatable pool so the hot path stays
        # exclusive. Align reservedSystemCPUs with the host isolcpus / the W1
        # k8s_reserved_cpus. Tune per node-profile (program 17).
        kubeReserved:
          cpu: "1"
          memory: "1Gi"
        systemReserved:
          cpu: "1"
          memory: "1Gi"
  extensions:
    helm:
      # We drive Helm releases from the workstation (Helmfile) to keep the
      # distribution-agnostic contract clean. Leave this empty.
      charts: []
      repositories: []
